# System Update - Multi-OS
# Template that includes the appropriate OS-specific update script

{{- if or (eq .chezmoi.osRelease.id "arch") (eq .chezmoi.osRelease.id "cachyos") (eq .chezmoi.osRelease.id "manjaro") }}
{{- include ".config/fish/functions/os_specific/update_arch.fish" }}
{{- else if eq .chezmoi.osRelease.id "debian" }}
{{- include ".config/fish/functions/os_specific/update_debian.fish" }}
{{- else }}
# Unsupported OS
function update
    echo "❌ Unsupported OS: {{ .chezmoi.osRelease.id }}"
    return 1
end
{{- end }}
