#!/usr/bin/env bash
# Hot edge pour Waybar - 3 états: hidden, visible, auto
# Usage: hotbar-toggle [cycle]  - cycle through states
#        hotbar-toggle          - run as daemon for auto mode

THRESHOLD=30        # Distance du haut (pixels)
HIDE_DELAY_SEC=0.8  # Délai avant cacher (secondes)
STATE_FILE="$XDG_RUNTIME_DIR/hyde/hotbar-state"

# États: hidden, visible, auto
STATES=("hidden" "visible" "auto")
DEFAULT_STATE="auto"

# Fonctions pour vraiment cacher/montrer waybar
show_waybar() {
    if ! pgrep -x waybar >/dev/null; then
        waybar &
    fi
}

hide_waybar() {
    if pgrep -x waybar >/dev/null; then
        killall waybar
    fi
}

# Initialiser
mkdir -p "$(dirname "$STATE_FILE")"
current_state=$(cat "$STATE_FILE" 2>/dev/null || echo "$DEFAULT_STATE")

# Mode cycle (raccourci clavier)
if [ "$1" = "cycle" ]; then
    # Trouver index actuel
    for i in "${!STATES[@]}"; do
        if [ "${STATES[$i]}" = "$current_state" ]; then
            next_index=$(( (i + 1) % ${#STATES[@]} ))
            new_state="${STATES[$next_index]}"
            echo "$new_state" > "$STATE_FILE"

            # Appliquer le changement
            case "$new_state" in
                hidden)
                    hide_waybar
                    notify-send -i "window-close" "Waybar" "Caché (souris inactive)"
                    ;;
                visible)
                    show_waybar
                    notify-send -i "window" "Waybar" "Visible (souris inactive)"
                    ;;
                auto)
                    show_waybar
                    notify-send -i "input-mouse" "Waybar" "Mode automatique (souris active)"
                    ;;
            esac
            exit 0
        fi
    done
fi

# Mode daemon (hot edge)
while true; do
    current_state=$(cat "$STATE_FILE" 2>/dev/null || echo "auto")

    # En mode auto, gérer la souris
    if [ "$current_state" = "auto" ]; then
        cursor_pos=$(hyprctl cursorpos 2>/dev/null | grep -oP '\d+,\d+' | head -1)
        [ -z "$cursor_pos" ] && cursor_pos="0,0"
        y=$(echo "$cursor_pos" | cut -d',' -f2)
        current_time=$(date +%s)

        # Lire le timestamp dernier action
        last_action_file="$STATE_FILE.lastaction"
        if [ -f "$last_action_file" ]; then
            last_action=$(cat "$last_action_file")
        else
            last_action=0
        fi

        if [ "$y" -lt "$THRESHOLD" ]; then
            # Souris en haut -> montrer
            show_waybar
            echo "$current_time" > "$last_action_file"
        else
            # Vérifier si le délai est passé
            elapsed=$((current_time - last_action))
            delay_int=1  # HIDE_DELAY_SEC arrondi à 1 seconde
            if [ "$elapsed" -ge "$delay_int" ] && [ "$last_action" -gt 0 ]; then
                # Cacher waybar
                hide_waybar
                echo "0" > "$last_action_file"
            fi
        fi
    fi

    sleep 0.15
done
