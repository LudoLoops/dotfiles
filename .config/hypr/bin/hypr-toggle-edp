#!/usr/bin/env bash
set -euo pipefail

STATE="${XDG_STATE_HOME:-$HOME/.local/state}/hypr"
FLAG="$STATE/edp_disabled"
mkdir -p "$STATE"

if [[ -f "$FLAG" ]]; then
  # Re-enable laptop display with preferred settings
  hyprctl keyword monitor "eDP-1,preferred,auto,1"
  rm -f "$FLAG"
else
  # Disable laptop display
  hyprctl keyword monitor "eDP-1, disable"
  touch "$FLAG"
fi
